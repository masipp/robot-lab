{
    "environment": "default",
    "algorithm": "PPO",
    "num_envs": 8,
    "total_timesteps": 500000,
    "hyperparameters": {
        "policy": "MlpPolicy",
        "learning_rate": 0.0003,
        "n_steps": 2048,
        "batch_size": 256,
        "n_epochs": 10,
        "gamma": 0.99,
        "gae_lambda": 0.95,
        "clip_range": 0.2,
        "use_sde": false,
        "sde_sample_freq": -1
    },
    "vec_normalize": {
        "norm_obs": true,
        "norm_reward": true,
        "clip_obs": 10.0
    },
    "notes": "Default PPO configuration. For MuJoCo environments (HalfCheetah, Walker2d), consider enabling gSDE by setting use_sde=true and sde_sample_freq=4."
}
