{
    "environment": "HalfCheetah-v5",
    "algorithm": "SAC",
    "num_envs": 8,
    "total_timesteps": 500000,
    "hyperparameters": {
        "policy": "MlpPolicy",
        "buffer_size": 300000,
        "learning_starts": 10000,
        "batch_size": 256,
        "tau": 0.005,
        "gamma": 0.99,
        "train_freq": 1,
        "gradient_steps": 1,
        "use_sde": true,
        "sde_sample_freq": 4
    },
    "vec_normalize": {
        "norm_obs": true,
        "norm_reward": true,
        "clip_obs": 10.0
    }
}
